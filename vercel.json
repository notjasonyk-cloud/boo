{
  "version": 2,
  "functions": {
    "api/*.js": {
      "includeFiles": "product_detail.html"
    }
  },
  "routes": [
    {
      "src": "/product/(?<slug>[a-zA-Z0-9_-]+)",
      "dest": "/api/index.js?slug=$slug"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/storage/(.*)",
      "dest": "/storage/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
